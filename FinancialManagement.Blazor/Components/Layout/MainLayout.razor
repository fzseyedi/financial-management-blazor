@inherits LayoutComponentBase
@using FinancialManagement.Blazor.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthStateProvider AuthStateProvider
@inject AuthApiService AuthApiService
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">
                            👤 @context.User.Identity?.Name
                        </span>
                        <a href="profile" class="btn btn-sm btn-outline-secondary">My Profile</a>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="LogoutAsync">
                            Sign out
                        </button>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private async Task LogoutAsync()
    {
        var tokenStore = AuthStateProvider.GetTokenStore();
        if (!string.IsNullOrEmpty(tokenStore?.RefreshToken))
        {
            try { await AuthApiService.LogoutAsync(tokenStore.RefreshToken); }
            catch { /* best-effort server revocation */ }
        }

        await AuthStateProvider.MarkUserAsLoggedOutAsync();
        NavigationManager.NavigateTo("/login", replace: true);
    }
}
