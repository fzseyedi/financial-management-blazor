@page "/customers"

@using FinancialManagement.Blazor.Components.Shared
@using FinancialManagement.Blazor.Models.Common
@using FinancialManagement.Blazor.Models.Customers
@using FinancialManagement.Blazor.Services.Customers
@using Microsoft.AspNetCore.Components.Web
@using FinancialManagement.Blazor.Components
@inject CustomerApiService CustomerApiService
@inject NavigationManager NavigationManager

<PageTitle>Customers</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Customers</h3>
    <button class="btn btn-primary" @onclick="GoToCreate">Create Customer</button>
</div>

<div class="mb-3">
    <div class="btn-group" role="group">
        <button type="button" class="btn @(_filterStatus == FilterStatus.All ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetFilterAsync(FilterStatus.All)">All Customers</button>
        <button type="button" class="btn @(_filterStatus == FilterStatus.Active ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetFilterAsync(FilterStatus.Active)">Active Only</button>
        <button type="button" class="btn @(_filterStatus == FilterStatus.Inactive ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetFilterAsync(FilterStatus.Inactive)">Inactive Only</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}
@if (_customers is null)
{
    <p>Loading...</p>
}
else if (_customers.Count == 0)
{
    <p>No customers found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var customer in _customers)
        {
            <tr>
                <td>@customer.Code</td>
                <td>@customer.Name</td>
                <td>@customer.Email</td>
                <td>@customer.Phone</td>
                <td>@customer.IsActive</td>
                <td>
                    <button class="btn btn-sm btn-primary" @onclick="() => GoToEdit(customer.Id)" disabled="@_isDeleting">Edit</button>
                    <button class="btn btn-sm @(customer.IsActive ? "btn-warning" : "btn-success")" @onclick="() => ToggleStatusAsync(customer)" disabled="@_isDeleting">@(customer.IsActive ? "Deactivate" : "Activate")</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmationAsync(customer)" disabled="@_isDeleting">Delete</button>
                </td>
            </tr>
        }
        </tbody>
    </table>

    <Pagination
        PageNumber="_pageNumber"
        PageSize="_pageSize"
        TotalCount="_totalCount"
        TotalPages="_totalPages"
        OnPageChanged="OnPageChangedAsync"
        OnPageSizeChanged="OnPageSizeChangedAsync" />
}

<ConfirmationModal
    IsVisible="_showDeleteModal"
    Title="Delete Customer"
    Message="@_deleteConfirmationMessage"
    ConfirmButtonText="Delete"
    CancelButtonText="Cancel"
    ButtonClass="btn-danger"
    IsLoading="@_isDeleting"
    OnConfirm="ConfirmDeleteAsync"
    OnCancel="CancelDeleteAsync" />

@code {
    private enum FilterStatus
    {
        All,
        Active,
        Inactive
    }

    private List<CustomerDto>? _customers;
    private string? _error;
    private string? _successMessage;
    private FilterStatus _filterStatus = FilterStatus.All;
    private bool _showDeleteModal;
    private bool _isDeleting;
    private CustomerDto? _customerToDelete;
    private string _deleteConfirmationMessage = string.Empty;

    private int _pageNumber = 1;
    private int _pageSize = 10;
    private int _totalCount;
    private int _totalPages;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        try
        {
            _error = null;

            var includeInactive = _filterStatus != FilterStatus.Active;
            var response = await CustomerApiService.GetAllPagedAsync(
                includeInactive: includeInactive,
                pageNumber: _pageNumber,
                pageSize: _pageSize);

            _customers = _filterStatus switch
            {
                FilterStatus.All => response.Items.ToList(),
                FilterStatus.Active => response.Items.Where(c => c.IsActive).ToList(),
                FilterStatus.Inactive => response.Items.Where(c => !c.IsActive).ToList(),
                _ => []
            };

            _totalCount = response.TotalCount;
            _totalPages = response.TotalPages;
            _pageNumber = response.PageNumber;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SetFilterAsync(FilterStatus filterStatus)
    {
        _filterStatus = filterStatus;
        _pageNumber = 1;
        await LoadCustomersAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _pageNumber = page;
        await LoadCustomersAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        _pageSize = pageSize;
        _pageNumber = 1;
        await LoadCustomersAsync();
    }

    private void GoToCreate()
    {
        NavigationManager.NavigateTo("/customers/create");
    }

    private void GoToEdit(int id)
    {
        NavigationManager.NavigateTo($"/customers/edit/{id}");
    }

    private async Task ToggleStatusAsync(CustomerDto customer)
    {
        try
        {
            _error = null;
            _successMessage = null;
            if (customer.IsActive)
            {
                await CustomerApiService.DeactivateAsync(customer.Id);
            }
            else
            {
                await CustomerApiService.ActivateAsync(customer.Id);
            }

            await LoadCustomersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ShowDeleteConfirmationAsync(CustomerDto customer)
    {
        _customerToDelete = customer;
        _deleteConfirmationMessage = $"Are you sure you want to delete customer '{customer.Code} - {customer.Name}'? This action cannot be undone.";
        _showDeleteModal = true;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_customerToDelete is null)
            return;

        _isDeleting = true;
        try
        {
            _error = null;
            await CustomerApiService.DeleteAsync(_customerToDelete.Id);
            _successMessage = $"Customer '{_customerToDelete.Code} - {_customerToDelete.Name}' has been successfully deleted.";
            _showDeleteModal = false;
            _customerToDelete = null;

            // Clear success message after 5 seconds
            _ = Task.Delay(5000).ContinueWith(async _ => 
            {
                await InvokeAsync(() =>
                {
                    _successMessage = null;
                    StateHasChanged();
                });
            });

            await LoadCustomersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _showDeleteModal = false;
            _customerToDelete = null;
            _deleteConfirmationMessage = string.Empty;
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private void CancelDeleteAsync()
    {
        _showDeleteModal = false;
        _customerToDelete = null;
        _deleteConfirmationMessage = string.Empty;
    }
}