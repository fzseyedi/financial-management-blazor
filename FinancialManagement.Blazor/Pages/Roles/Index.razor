@page "/roles"
@attribute [Authorize(Roles = "Admin")]
@using FinancialManagement.Blazor.Models.Users
@using FinancialManagement.Blazor.Services.Users
@using Microsoft.AspNetCore.Components.Web
@inject RoleApiService RoleApiService
@inject NavigationManager NavigationManager

<PageTitle>Roles</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Roles</h3>
    <button class="btn btn-primary" @onclick="GoToCreate">Create Role</button>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrWhiteSpace(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

@if (_roles is null)
{
    <p>Loading...</p>
}
else if (_roles.Count == 0)
{
    <p>No roles found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in _roles)
            {
                <tr>
                    <td>@role.Name</td>
                    <td>@role.Description</td>
                    <td>
                        <button class="btn btn-sm btn-primary me-1" @onclick="() => GoToEdit(role.Id)" disabled="@_isBusy">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsync(role.Id)" disabled="@_isBusy">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<RoleDto>? _roles;
    private string? _error;
    private string? _successMessage;
    private bool _isBusy;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _roles = await RoleApiService.GetAllAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load roles: {ex.Message}";
        }
    }

    private async Task DeleteAsync(int id)
    {
        _error = null;
        _successMessage = null;
        _isBusy = true;
        try
        {
            await RoleApiService.DeleteAsync(id);
            _successMessage = "Role deleted.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to delete role: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void GoToCreate() => NavigationManager.NavigateTo("/roles/create");
    private void GoToEdit(int id) => NavigationManager.NavigateTo($"/roles/edit/{id}");
}
